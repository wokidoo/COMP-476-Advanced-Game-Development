[sub_resource type="GDScript" id="GDScript_60spa"]
resource_name = "Grounded"
script/source = "extends State

@export var player:Player3D

func state_enter() -> void:
	# Guarentees buffer timer to be initialized before using it
	if not player.is_node_ready():
		await player.ready
	player.capture_mouse()
	player.velocity.y = 0.0
	# If jump is buffered, immediately start a new jump
	if player.is_jump_buffered():
		state_machine.execute_event(\"jump\")
	elif Input.is_action_pressed(\"sprint\"):
		state_machine.execute_event(\"sprinting\")
	
func state_exit() -> void:
	pass
	
func state_input(event: InputEvent) -> void:
	if event.is_action_pressed(\"sprint\"):
		state_machine.execute_event(\"sprinting\")
	if event.is_action_pressed(\"jump\"):
		state_machine.execute_event(\"jump\")
	
func state_physics_process(delta: float) -> void:
	var current_h_velocity: Vector3 = player.velocity
	current_h_velocity.y = 0.0
	var target_h_velocity: Vector3 = Vector3.ZERO
	var final_h_velocity: Vector3
	
	if current_h_velocity.length() > player.walk_speed:
		final_h_velocity = current_h_velocity.lerp(target_h_velocity,player.sprint_deceleration * delta)
	elif not player.input_direction.is_zero_approx():
		target_h_velocity = player.walk_speed * player.input_direction
		final_h_velocity = current_h_velocity.lerp(target_h_velocity,player.walk_acceleration * delta)
	else:
		final_h_velocity = current_h_velocity.lerp(target_h_velocity,player.walk_deceleration * delta)

	player.velocity.x = final_h_velocity.x
	player.velocity.z = final_h_velocity.z
	
	player.move_and_slide()
	if not player.is_on_floor():
		state_machine.execute_event(\"falling\")
"

[sub_resource type="GDScript" id="GDScript_1c71w"]
resource_name = "Sprinting"
script/source = "extends State

@export var player:Player3D

func state_enter() -> void:
	pass

func state_exit() -> void:
	pass

func state_input(event: InputEvent) -> void:
	if event.is_action_released(\"sprint\"):
		state_machine.execute_event(\"walking\")
	if event.is_action_pressed(\"jump\"):
		state_machine.execute_event(\"jump\")

func state_physics_process(delta: float) -> void:
	var current_h_velocity: Vector3 = player.velocity
	current_h_velocity.y = 0.0
	var target_h_velocity: Vector3 = player.sprint_speed * player.input_direction
	var final_h_velocity: Vector3 = Vector3.ZERO

	if is_zero_approx(player.input_direction.length_squared()):
		target_h_velocity = Vector3.ZERO
		final_h_velocity = current_h_velocity.lerp(target_h_velocity,player.walk_deceleration * delta)
	else:
		final_h_velocity = current_h_velocity.lerp(target_h_velocity,player.sprint_acceleration * delta)
	
	player.velocity.x = final_h_velocity.x
	player.velocity.z = final_h_velocity.z
	player.move_and_slide()
	
	if not player.is_on_floor():
		state_machine.execute_event(\"falling\")
	if not Input.is_action_pressed(\"sprint\"):
		state_machine.execute_event(\"walking\")
"

[sub_resource type="GDScript" id="GDScript_efhua"]
resource_name = "Jumping"
script/source = "extends State

@export var player:Player3D

func state_enter() -> void:
	player.velocity.y += player.jump_force

func state_exit() -> void:
	pass # Replace with function body.

func state_input(event: InputEvent) -> void:
	if event.is_action_released(\"sprint\"):
		state_machine.execute_event(\"grounded\")
	elif event.is_action_pressed(\"jump\"):
		player.buffer_jump()

func state_physics_process(delta: float) -> void:
	var current_horiz_velocity: Vector3 = player.velocity
	current_horiz_velocity.y = 0.0

	var target_horiz_velocity: Vector3
	var final_horiz_velocity: Vector3 = Vector3.ZERO

	player.velocity.y -= (player.jump_gravity * delta)
	if player.input_direction and current_horiz_velocity.length() > player.air_speed:
		target_horiz_velocity = player.air_speed * player.input_direction
		final_horiz_velocity = current_horiz_velocity.lerp(target_horiz_velocity,player.air_deceleration * delta)
	elif player.input_direction:
		target_horiz_velocity = player.air_speed * player.input_direction
		final_horiz_velocity = current_horiz_velocity.lerp(target_horiz_velocity,player.air_acceleration * delta)
	else:
		target_horiz_velocity = current_horiz_velocity
		final_horiz_velocity = current_horiz_velocity.lerp(target_horiz_velocity,player.air_deceleration * delta)
	
	player.velocity.x = final_horiz_velocity.x
	player.velocity.z = final_horiz_velocity.z
	player.move_and_slide()
	
	if player.is_on_floor():
		state_machine.execute_event(\"walking\")
	if player.velocity.y < 0.0 or is_zero_approx(player.velocity.y):
		state_machine.execute_event(\"falling\")
	
"

[sub_resource type="GDScript" id="GDScript_5x08c"]
resource_name = "Falling"
script/source = "extends State

@export var player:Player3D

func state_enter() -> void:
	pass # Replace with function body.

func state_exit() -> void:
	pass # Replace with function body.

func state_input(event: InputEvent) -> void:
	if event.is_action_pressed(\"jump\"):
		player.buffer_jump()

func state_physics_process(delta: float) -> void:
	var current_horiz_velocity: Vector3 = player.velocity
	current_horiz_velocity.y = 0.0

	var target_horiz_velocity: Vector3
	var final_horiz_velocity: Vector3 = Vector3.ZERO

	player.velocity.y -= (player.fall_gravity * delta)
	if player.input_direction and current_horiz_velocity.length() > player.air_speed:
		target_horiz_velocity = player.air_speed * player.input_direction
		final_horiz_velocity = current_horiz_velocity.lerp(target_horiz_velocity,player.air_deceleration * delta)
	elif player.input_direction:
		target_horiz_velocity = player.air_speed * player.input_direction
		final_horiz_velocity = current_horiz_velocity.lerp(target_horiz_velocity,player.air_acceleration * delta)
	else:
		target_horiz_velocity = current_horiz_velocity
		final_horiz_velocity = current_horiz_velocity.lerp(target_horiz_velocity,player.air_deceleration * delta)
	
	player.velocity.x = final_horiz_velocity.x
	player.velocity.z = final_horiz_velocity.z
	player.move_and_slide()

	if player.is_on_floor():
		state_machine.execute_event(\"walking\")
